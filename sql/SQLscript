-- 1 Criando o database e selecionando-a para uso
DROP DATABASE IF EXISTS ftcoin;
CREATE DATABASE IF NOT EXISTS ftcoin;
USE ftcoin;

-- 2 Criando a tabela Carteira
CREATE TABLE IF NOT EXISTS CARTEIRA (
    IdCarteira INT AUTO_INCREMENT PRIMARY KEY,
    Titular VARCHAR(50) NOT NULL,
    Corretora VARCHAR(50) NOT NULL
) ENGINE=InnoDB;

-- 3 Criando a tabela Movimentacao
CREATE TABLE IF NOT EXISTS MOVIMENTACAO (
    IdCarteira INT NOT NULL,
    IdMovimento INT PRIMARY KEY AUTO_INCREMENT,
    Data DATE,
    TipoOperacao CHAR(1),
    Quantidade DECIMAL(10,3),
    FOREIGN KEY (IdCarteira) REFERENCES CARTEIRA(IdCarteira)
) ENGINE=InnoDB;

-- 4 Criando a tabela Oraculo
CREATE TABLE IF NOT EXISTS ORACULO (
    Data DATE NOT NULL,
    Cotacao DECIMAL(6,2) NOT NULL
) ENGINE=InnoDB;

-- 5 Índices auxiliares para otimização de consultas
CREATE INDEX idx_movimentacao_carteira ON MOVIMENTACAO(IdCarteira);
CREATE INDEX idx_movimentacao_data ON MOVIMENTACAO(Data);

